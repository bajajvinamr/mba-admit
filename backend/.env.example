# ── Application Settings ──
ENVIRONMENT=development
PORT=8000
FRONTEND_URL=http://localhost:3000

# ── API Keys for Intelligent Agents ──
# Get OpenAI key: https://platform.openai.com/api-keys (needed for generating Embeddings)
OPENAI_API_KEY=your_openai_api_key_here

# Get Anthropic key: https://console.anthropic.com/ (needed for Claude 3.5 Sonnet to write essays)
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# ── Database & State ──
# (Optional) We use local file-based Qdrant by default for MVP.
# If scaling, add QDRANT_URL and QDRANT_API_KEY here.

# Redis (optional — falls back to in-memory if unavailable)
REDIS_URL=redis://localhost:6379/0
